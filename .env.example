# ── Supabase (required) ──────────────────────────────────────────────────────
# Get these from: supabase.com/dashboard → your project → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here   # server-only, never expose to client

# ── Admin / internal ─────────────────────────────────────────────────────────
ADMIN_PASSWORD=change_me_in_production

# ── App URL (required for Stripe redirects + email links) ────────────────────
NEXT_PUBLIC_APP_URL=https://your-domain.com   # no trailing slash

# ── Stripe (payments) ────────────────────────────────────────────────────────
# dashboard.stripe.com → API keys (use test keys during dev)
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_MONTHLY=price_...
STRIPE_PRICE_ANNUAL=price_...

# ── Twilio (SMS — weekly digests, event reminders, Yande texts) ──────────────
# console.twilio.com
TWILIO_ACCOUNT_SID=ACxxxxxx
TWILIO_AUTH_TOKEN=xxxxxx
TWILIO_FROM_NUMBER=+1xxxxxxxxxx

# ── Cron secret ───────────────────────────────────────────────────────────────
# Any random string — used to authenticate Vercel cron → your API routes
CRON_SECRET=change_me_in_production

# ══════════════════════════════════════════════════════════════════════════════
#  YANDE AI ENGINE
#  All keys below are optional at launch — code skips gracefully if not set.
#  Add a key = feature activates automatically on next cron run.
# ══════════════════════════════════════════════════════════════════════════════

# ── Claude / Anthropic (Yande's brain) ───────────────────────────────────────
# Required for ALL AI features (Yande notes, Avenue editors, City Intelligence)
# console.anthropic.com → API keys
ANTHROPIC_API_KEY=sk-ant-...

# ── Apify — TikTok scraper ────────────────────────────────────────────────────
# Powers: TikTok trend layer in City Intelligence + Girl Working work-sentiment
# Starter plan: $49/month (250 compute units — enough for 6+ months at current volume)
# Sign up: apify.com → create account → Settings → Integrations → API token
# Actor used: clockworks/tiktok-hashtag-scraper
# DORMANT until this key is added
APIFY_API_KEY=apify_api_...

# ── Yelp Fusion API ───────────────────────────────────────────────────────────
# Powers: top-rated NYC spots layer in City Intelligence
# FREE — 5,000 calls/day forever on the free plan
# Get key: yelp.com/developers → Create App → copy "API Key"
# DORMANT until this key is added
YELP_API_KEY=...

# ── Google Places API ─────────────────────────────────────────────────────────
# Powers: prominent NYC places layer in City Intelligence
# FREE up to $200/month (covers ~40,000 place searches — way more than needed)
# Get key: console.cloud.google.com → APIs & Services → Credentials → Create API key
#   Then enable: "Places API" in the APIs library
# DORMANT until this key is added
GOOGLE_PLACES_API_KEY=...

# ── Eventbrite API ────────────────────────────────────────────────────────────
# Powers: NYC events + pop-ups layer in City Intelligence
# FREE — 1,000 requests/day
# Get key: eventbrite.com/platform/api → Create App → copy API key
# DORMANT until this key is added
EVENTBRITE_API_KEY=...

# ── Whop (legacy — keep if you have active Whop memberships) ─────────────────
WHOP_API_KEY=
WHOP_PLAN_ID=plan_...
WHOP_WEBHOOK_SECRET=
